FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc curl && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    fastapi==0.111.0 \
    uvicorn[standard]==0.29.0 \
    asyncpg==0.29.0 \
    pydantic==2.7.1 \
    python-dotenv==1.0.1

COPY configs/ ./configs/
COPY api/ ./api/

ENV PYTHONPATH=/app

EXPOSE 8000
CMD ["python", "-m", "api.main"]
